{
  "model_config": {
    "classification": {
      "default_model": "logistic",
      "logistic_regression": {
        "C": 1.0,
        "solver": "lbfgs",
        "max_iter": 1000,
        "random_state": 42
      },
      "neural_network": {
        "input_size": 15,
        "hidden_sizes": [128, 64, 32],
        "dropout_rate": 0.3,
        "learning_rate": 0.001,
        "epochs": 50,
        "batch_size": 32
      }
    },
    "forecasting": {
      "default_model": "arima",
      "linear": {
        "lookback": 24,
        "degree": 1
      },
      "arima": {
        "order": [1, 1, 1],
        "seasonal_order": [0, 0, 0, 0]
      },
      "prophet": {
        "interval_width": 0.95,
        "seasonality_mode": "additive",
        "changepoint_prior_scale": 0.05,
        "seasonality_scale": 10,
        "yearly_seasonality": false,
        "weekly_seasonality": true,
        "daily_seasonality": true
      }
    }
  },
  "data_config": {
    "test_size": 0.2,
    "random_state": 42,
    "normalization_method": "standard",
    "missing_value_method": "interpolate",
    "outlier_method": "iqr"
  },
  "evaluation_config": {
    "classification_metrics": ["accuracy", "precision", "recall", "f1", "roc_auc"],
    "forecasting_metrics": ["mae", "rmse", "mape", "r2"]
  },
  "paths": {
    "models_dir": "models/",
    "data_dir": "data/",
    "logs_dir": "logs/"
  }
}
